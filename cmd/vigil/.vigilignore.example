# vigil - Patterns to exclude from project structure generation
# Like .gitignore, these patterns will be skipped when generating the tree

# Dependencies
node_modules/
vendor/
.venv/
venv/
__pycache__/

# Build outputs
dist/
build/
target/
.wrangler/

# IDE
.idea/
.vscode/
*.swp
*.swo
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env files
.env
.env.*
.envrc
.dev.vars

# Databases
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Lock files (optional)
pnpm-lock.yaml
package-lock.json
go.sum

# Test coverage
coverage/
.nyc_output/

# Temporary
_old/
_backup/
tmp/
temp/
